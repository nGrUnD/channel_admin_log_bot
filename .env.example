BOT_TOKEN=123456:ABC-DEF...

# my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash
# StringSession после scripts/create_session.py
TELEGRAM_SESSION=

# Если create_session.py падает с TimeoutError — нужен прокси для MTProto.
# Пример: локальный SOCKS5 от VPN (V2Ray, Clash и т.п.)
# TELEGRAM_PROXY_TYPE=socks5
# TELEGRAM_PROXY_HOST=127.0.0.1
# TELEGRAM_PROXY_PORT=1080
# TELEGRAM_PROXY_USERNAME=
# TELEGRAM_PROXY_PASSWORD=
# MTProxy:
# TELEGRAM_PROXY_TYPE=mtproxy
# TELEGRAM_PROXY_HOST=proxy.example.com
# TELEGRAM_PROXY_PORT=443
# TELEGRAM_MTPROXY_SECRET=...
# TELEGRAM_CONNECT_TIMEOUT=60

CHANNEL_USERNAME=@mychannel

# Telegram ID админов бота (через запятую)
ADMIN_IDS=123456789
# Кому слать уведомления (по умолчанию = ADMIN_IDS)
ADMIN_NOTIFY_IDS=123456789

# Типы событий для push-уведомлений
NOTIFY_EVENT_TYPES=join,leave,ban,kick,unban

POLL_INTERVAL_SECONDS=30
INITIAL_BACKFILL_LIMIT=500
DATABASE_PATH=data/bot.db
